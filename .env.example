# =============================================================================
# OpportunityOS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all required values.
# NEVER commit .env to git. It is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (required)
# -----------------------------------------------------------------------------
POSTGRES_DB=opportunityos
POSTGRES_USER=opp_user
POSTGRES_PASSWORD=changeme_use_a_strong_password
DATABASE_URL=postgresql://opp_user:changeme_use_a_strong_password@db:5432/opportunityos

# -----------------------------------------------------------------------------
# TELEGRAM (required)
# Get TELEGRAM_BOT_TOKEN from @BotFather on Telegram.
# Get TELEGRAM_CHAT_ID by messaging @userinfobot on Telegram.
# ALLOWED_USER_IDS: comma-separated Telegram user IDs that may use the bot.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALLOWED_USER_IDS=

# -----------------------------------------------------------------------------
# GITHUB (recommended — not required)
# Unauthenticated: 10 req/min. Authenticated: 30 req/min.
# Get a free token at: https://github.com/settings/tokens
# No scopes needed — public data only.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# PIPELINE CONFIGURATION
# -----------------------------------------------------------------------------
PIPELINE_HOUR=8              # Hour to run daily digest (24h format, local time)
PIPELINE_MINUTE=0            # Minute to run daily digest
DIGEST_MAX_ITEMS=10          # Maximum items per daily digest (see SCHEMA_SPEC Section 8)
MIN_SCORE_THRESHOLD=40       # Minimum score to appear in digest

# -----------------------------------------------------------------------------
# TIMEZONE
# Must match your local timezone for the pipeline to fire at the right time.
# List: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# -----------------------------------------------------------------------------
TZ=Asia/Kolkata
